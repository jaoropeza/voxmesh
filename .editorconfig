root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cpp,hpp,h,cc}]
indent_size = 4
max_line_length = 120

[*.{cs,csproj,sln}]
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json,yml,yaml}]
indent_size = 2

[*.{proto,qml}]
indent_size = 2

[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
