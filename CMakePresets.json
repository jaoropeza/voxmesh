{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/conan/conan_toolchain.cmake"
      }
    },
    {
      "name": "windows-debug",
      "inherits": "base",
      "displayName": "Windows x64 Debug (default VS generator)",
      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": { "CMAKE_CONFIGURATION_TYPES": "Debug" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "windows-release",
      "inherits": "windows-debug",
      "displayName": "Windows x64 Release",
      "cacheVariables": { "CMAKE_CONFIGURATION_TYPES": "Release" }
    },
    {
      "name": "linux-debug",
      "inherits": "base",
      "displayName": "Linux Debug",
      "generator": "Ninja",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-release",
      "inherits": "linux-debug",
      "displayName": "Linux Release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux-asan-ubsan",
      "inherits": "linux-debug",
      "displayName": "Linux ASan+UBSan",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "linux-tsan",
      "inherits": "linux-debug",
      "displayName": "Linux TSan",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
      }
    },
    {
      "name": "linux-coverage",
      "inherits": "linux-debug",
      "displayName": "Linux coverage",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "--coverage",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage"
      }
    },
    {
      "name": "macos-arm64-debug",
      "inherits": "base",
      "displayName": "macOS arm64 Debug",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "macos-arm64-release",
      "inherits": "macos-arm64-debug",
      "displayName": "macOS arm64 Release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "macos-x64-debug",
      "inherits": "macos-arm64-debug",
      "displayName": "macOS x86_64 Debug",
      "cacheVariables": { "CMAKE_OSX_ARCHITECTURES": "x86_64" }
    },
    {
      "name": "macos-x64-release",
      "inherits": "macos-x64-debug",
      "displayName": "macOS x86_64 Release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "macos-universal-release",
      "inherits": "macos-arm64-release",
      "displayName": "macOS universal Release (requires universal-built dependencies)",
      "cacheVariables": { "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64" }
    }
  ],
  "buildPresets": [
    { "name": "windows-debug", "configurePreset": "windows-debug", "configuration": "Debug" },
    { "name": "windows-release", "configurePreset": "windows-release", "configuration": "Release" },
    { "name": "linux-debug", "configurePreset": "linux-debug" },
    { "name": "linux-release", "configurePreset": "linux-release" },
    { "name": "linux-asan-ubsan", "configurePreset": "linux-asan-ubsan" },
    { "name": "linux-tsan", "configurePreset": "linux-tsan" },
    { "name": "linux-coverage", "configurePreset": "linux-coverage" },
    { "name": "macos-arm64-debug", "configurePreset": "macos-arm64-debug" },
    { "name": "macos-arm64-release", "configurePreset": "macos-arm64-release" },
    { "name": "macos-x64-debug", "configurePreset": "macos-x64-debug" },
    { "name": "macos-x64-release", "configurePreset": "macos-x64-release" }
  ],
  "testPresets": [
    {
      "name": "test-base",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error" }
    },
    { "name": "windows-debug", "inherits": "test-base", "configurePreset": "windows-debug", "configuration": "Debug" },
    { "name": "windows-release", "inherits": "test-base", "configurePreset": "windows-release", "configuration": "Release" },
    { "name": "linux-debug", "inherits": "test-base", "configurePreset": "linux-debug" },
    { "name": "linux-release", "inherits": "test-base", "configurePreset": "linux-release" },
    { "name": "linux-asan-ubsan", "inherits": "test-base", "configurePreset": "linux-asan-ubsan" },
    { "name": "linux-tsan", "inherits": "test-base", "configurePreset": "linux-tsan" },
    { "name": "linux-coverage", "inherits": "test-base", "configurePreset": "linux-coverage" },
    { "name": "macos-arm64-debug", "inherits": "test-base", "configurePreset": "macos-arm64-debug" },
    { "name": "macos-x64-debug", "inherits": "test-base", "configurePreset": "macos-x64-debug" }
  ]
}
